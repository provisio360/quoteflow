{
  "name": "quoteflow",
  "version": "0.1.0",
  "private": true,
  "description": "QuoteFlow — multi-tenant pricing-study platform (walking skeleton)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:smoke": "tsx scripts/db-smoke.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "worker": "tsx worker/index.ts",
    "worker:once": "tsx worker/run-once.ts"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "better-auth": "^1.6.13",
    "dotenv": "^16",
    "graphile-worker": "^0.16",
    "kysely": "^0.28.17",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^6",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
