# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# QuoteFlow local environment.

# Neon Postgres — get these from the Neon dashboard (https://neon.tech).
# DATABASE_URL is the POOLED connection (hostname contains "-pooler"); used by the app.
# DIRECT_URL is the same connection WITHOUT "-pooler"; used by Prisma for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Better Auth (#3) — app-owned email/password auth (ADR-0005/0006).
# Generate a strong secret: `node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"`
BETTER_AUTH_SECRET="generate-a-32-byte-random-secret"
BETTER_AUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Identity config — invite expiry window (grilling Q5).
INVITE_EXPIRY_DAYS="7"

# One-shot admin bootstrap (scripts/seed-admin.ts). Leave blank in normal runs.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""
SEED_ADMIN_NAME="QuoteFlow Admin"
