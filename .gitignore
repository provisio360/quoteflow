.DS_Store
**/.DS_Store

# Local research / scratch notes — non-authoritative, never committed
research/

# Per-agent local memory store (path-keyed, machine-specific) — never committed.
# The shared .claude/skills/ stays tracked; only this agent state is excluded.
.claude/projects/

# Secrets & local env — never commit connection strings or API keys
.env
.env.*
!.env.example

# Generated pricing-study spreadsheets (local scratch outputs, non-authoritative)
pricing_study_*.xlsx

# Excel lock files (created while a workbook is open)
~$*.xlsx

# Node / build output
node_modules/
.next/
dist/
build/
coverage/
*.log
*.tsbuildinfo
