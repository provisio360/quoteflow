// QuoteFlow database schema.
// `url` is the POOLED Neon connection (app runtime); `directUrl` is the DIRECT
// connection (migrations) — see ADR-0005 and .env.example.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Trivial entity for the walking skeleton: proves a real write+read round-trip
// to Neon. Real domain models (Pricing Study, Benchmark Item, Quote, …) arrive
// with their slices (#3 onward).
model HealthCheck {
  id        String   @id @default(cuid())
  note      String
  createdAt DateTime @default(now())

  @@map("health_check")
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity (#3) — invite-only login, roles, tenant binding.
// See CONTEXT.md (Admin, Client, Client User, Invite) and ADRs 0001/0006/0007.
// ─────────────────────────────────────────────────────────────────────────────

/// internal = staff (carries a role, no tenant); client = Client User (one tenant, no role).
enum PrincipalKind {
  internal
  client
}

/// The four internal staff roles. Admin is user-administration only.
enum InternalRole {
  Admin
  EngagementManager
  Researcher
  Analyst
}

/// Offboarding is reversible deactivation, never deletion (ADR-0006 / grilling Q6).
enum UserStatus {
  active
  deactivated
}

/// A Client is the tenant (ADR-0001): a company, not a person — it never logs in.
/// Minimal here; Pricing Studies and the rest of the tenant's data arrive in #4+.
model Client {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users   User[]
  invites Invite[]
  studies Study[]

  @@map("client")
}

/// The principal. The internal/client split + role-XOR-tenant invariant is also
/// enforced by a DB CHECK constraint added in the migration (the pure mirror of
/// src/domains/authz Principal). Better Auth owns the base columns; kind/role/
/// tenantId/status/deactivatedAt are our additionalFields, never client-settable.
model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  // QuoteFlow identity fields:
  kind          PrincipalKind
  role          InternalRole?
  tenantId      String?
  status        UserStatus    @default(active)
  deactivatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Client?   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sessions       Session[]
  accounts       Account[]
  invitesCreated Invite[]  @relation("InvitedBy")
  studiesCreated Study[]   @relation("StudyCreatedBy")

  countryAssignments CountryAssignment[] @relation("AssignedResearcher")
  assignmentsMade    CountryAssignment[] @relation("AssignedBy")
  itemsAsPrimary     BenchmarkItem[]     @relation("PrimaryResearcher")
  marketQuotesCreated MarketQuote[]      @relation("MarketQuoteCreatedBy")
  quoteLinesCreated   QuoteLine[]        @relation("QuoteLineCreatedBy")
  quoteLinesReviewed  QuoteLine[]        @relation("QuoteLineReviewedBy")
  countriesReleased  CountryRelease[]    @relation("ReleasedBy")
  countriesReopened  CountryRelease[]    @relation("ReopenedBy")
  exportsRun         ExportAudit[]       @relation("ExportRunBy")
  auditEvents        AuditEvent[]        @relation("AuditActor")
  notifications      Notification[]      @relation("NotificationRecipient")

  @@index([tenantId])
  @@map("user")
}

/// Better Auth session — opaque server-side session (ADR-0006). Deactivating a
/// user or resetting a password deletes their sessions so access ends at once.
model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

/// Better Auth account — the authentication method, separated from the principal
/// (ADR-0007). v1 has exactly one providerId: "credential" (email/password, hash
/// in `password`). SSO later = a new account row pointing at the same User.
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

/// Better Auth verification — backs email-ownership / password-reset tokens.
model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
  @@map("verification")
}

/// An Admin's single-use, expiring offer to create one account (CONTEXT.md: Invite).
/// Carries the bindings chosen up front (role XOR tenant). Only the token HASH is
/// stored. Accepting it creates the User and is itself the email verification.
model Invite {
  id          String        @id @default(cuid())
  email       String
  kind        PrincipalKind
  role        InternalRole?
  tenantId    String?
  tokenHash   String        @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  invitedById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  invitedBy User    @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Restrict)
  tenant    Client? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([tenantId])
  @@map("invite")
}

// ─────────────────────────────────────────────────────────────────────────────
// Pricing Study (#4) — the first tenant-owned resource and the isolation tracer.
// See CONTEXT.md (Pricing Study) and ADR-0001 (Client = tenant) / ADR-0008
// (app-layer visibility policy; reads go through src/lib/studies only).
// ─────────────────────────────────────────────────────────────────────────────

/// A top-level project container scoped to exactly one Client (the tenant).
/// `clientId` IS the tenant binding — the whole point of the slice — and is
/// NON-NULL with onDelete: Restrict so a study can never escape the tenant
/// filter or point at a vanished tenant (grilling Q4: the security-load-bearing
/// part). The items/people/quotes a study "holds" arrive in later slices.
model Study {
  id             String   @id @default(cuid())
  name           String
  clientId       String
  createdById    String
  // The study's default QC Threshold (CONTEXT.md / ADR-0014): how far a Quote's
  // USD price-per-unit may diverge from a Benchmark Item's Client Price before it
  // is flagged. Required — a study without one is mis-configured — and set at
  // study setup by the EM/Analyst. Stored as a FRACTION (e.g. 0.2500 = 25%), the
  // same unit as the per-item BenchmarkItem.qcThreshold that overrides it (#86).
  qcThreshold Decimal  @db.Decimal(6, 4)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client    Client @relation(fields: [clientId], references: [id], onDelete: Restrict)
  createdBy User   @relation("StudyCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  benchmarkItems     BenchmarkItem[]
  countryAssignments CountryAssignment[]
  countryReleases    CountryRelease[]
  marketQuotes         MarketQuote[]
  quoteNumberSequences QuoteNumberSequence[]
  exchangeRates        StudyExchangeRate[]

  @@index([clientId])
  @@index([createdById])
  @@map("study")
}

/// A per-Pricing-Study manual local-currency→USD exchange rate an Engagement
/// Manager or Analyst seeds on study setup (ADR-0041, CONTEXT.md: Study Exchange
/// Rate). Keyed by `(study, currency, rateDate)` — by CURRENCY (ISO 4217), never
/// country, so a shared currency (EUR across France + Germany) holds one rate per
/// date and a dealer-country currency (COP on a Brazil-market study, ADR-0032) is
/// representable. `rate` is Decimal(18,8) — the pinned Exchange Rate's precision;
/// it does NOT feed conversion yet (a later slice). USD needs no row (rate ≡ 1).
/// `clientId` is the RLS backstop (ADR-0021), copied from the study on insert and
/// verified by WITH CHECK. Set/edit writes a `studyRateSet` Audit Event.
model StudyExchangeRate {
  id       String   @id @default(cuid())
  studyId  String
  // Denormalized owning tenant — the RLS backstop column (ADR-0021), copied from
  // the parent study on insert; verified by WITH CHECK.
  clientId String
  // ISO 4217 code, currency→USD. USD is refused at the app layer (rate ≡ 1).
  currency String
  // The date this rate applies from (a calendar day; lookup semantics are a later
  // slice). Stored as a date-only column.
  rateDate DateTime @db.Date
  rate     Decimal  @db.Decimal(18, 8)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  study Study @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@unique([studyId, currency, rateDate])
  @@index([studyId])
  @@index([clientId])
  @@map("study_exchange_rate")
}

// ─────────────────────────────────────────────────────────────────────────────
// Benchmark Item (#5) — the client's part to be price-benchmarked, loaded via
// all-or-nothing spreadsheet import. See CONTEXT.md (Benchmark Item, Required
// Quotes, Client Price) and ADR-0009 (import is source of truth; upsert key).
// ─────────────────────────────────────────────────────────────────────────────

/// One client part to price, within a study. Identity is (client part number +
/// country); `clientPartNumberKey` is the case-folded part number and `country`
/// the canonical name, so the @@unique IS the upsert key a re-import resolves on
/// (ADR-0009). `clientPartNumber` keeps the first-seen casing for display.
/// `clientPrice` is the analyst's expected USD price-per-unit (ADR-0003),
/// nullable: the brief only *seeds* it and an unpriced item carries none
/// (ADR-0015). The analyst owns it thereafter — a re-import never overwrites it.
model BenchmarkItem {
  id                   String   @id @default(cuid())
  studyId              String
  // Denormalized owning tenant, the RLS backstop column (ADR-0021). Immutable,
  // copied from the parent study on insert; the WITH CHECK policy verifies it
  // equals the request's tenant GUC. Not an FK — a plain scoping scalar, like
  // the other denormalized study/client ids on the audit/export trails.
  clientId             String
  country              String
  // The Benchmark Item identity within a study, with country (ADR-0009). Renamed
  // from clientPartNumber in #86 to match the real brief column "Client Item
  // Number"; the *Key is the folded (trim/lowercase) form the upsert matches on.
  clientItemNumber     String
  clientItemNumberKey  String
  itemDescription      String
  configurationComment String?
  quantity             Int?
  // Descriptive client-brief context (#86), all nullable — not every brief
  // carries them. clientSourceUnit is the renamed machineModel (the machine/model
  // the part belongs to, e.g. "BRC8T450X"); sourceUnitIdentifier is its optional
  // variant. clientItemOffering is "Standard" | "Premium" (validated at import).
  clientSourceUnit        String?
  sourceUnitIdentifier    String?
  clientCategory          String?
  clientItemOffering      String?
  itemSecondaryDescription String?
  clientSecondaryItemNumber String?
  requiredQuotes       Int
  // Per-item QC Threshold as a FRACTION (e.g. 0.2500 = 25%; CONTEXT.md / ADR-0014
  // amended by #86). Null falls back to Study.qcThreshold. Same unit at both
  // levels so the fallback never mixes scales.
  qcThreshold          Decimal? @db.Decimal(6, 4)
  // Advisory competitor brands the client wants benchmarked (CONTEXT.md: Required
  // Competitors). Ordered, up to 10, never a release gate; empty is normal — hence the
  // empty-array default, matching the column's `DEFAULT ARRAY[]::TEXT[]`. Without the
  // `@default`, Prisma sends an explicit NULL on create when the field is omitted,
  // bypassing the DB default and tripping the NOT NULL constraint.
  requiredCompetitors  String[] @default([])
  // The operative Client Price: derived USD/unit (price / priceQuantity), analyst-
  // owned after seeding — re-import never overwrites it (ADR-0015).
  clientPrice          Decimal? @db.Decimal(14, 4)
  // Client Price seed provenance — the raw brief trio it was first derived from
  // (ADR-0027). Insert-only like clientPrice; null when the item is unpriced.
  clientItemPrice         Decimal? @db.Decimal(14, 4)
  clientItemPriceCurrency String?
  clientItemPriceQuantity Decimal? @db.Decimal(14, 4)
  // The single lead Researcher on this item (CONTEXT.md: Primary Researcher),
  // set when a researcher self-assigns (#7). Null = unclaimed. First-come and
  // never stolen: the claim is a conditional update on this being NULL. Restrict
  // on delete is moot in practice (staff are deactivated, never deleted) but
  // keeps a lead from pointing at a vanished user; #25 nulls it on Country
  // unassignment.
  primaryResearcherId  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  study             Study   @relation(fields: [studyId], references: [id], onDelete: Cascade)
  primaryResearcher User?   @relation("PrimaryResearcher", fields: [primaryResearcherId], references: [id], onDelete: Restrict)
  quoteLines        QuoteLine[]

  @@unique([studyId, country, clientItemNumberKey])
  @@index([studyId])
  @@index([primaryResearcherId])
  @@index([clientId])
  @@map("benchmark_item")
}

// ─────────────────────────────────────────────────────────────────────────────
// Country Assignment (#6) — the Engagement Manager puts Researchers onto a
// Country within a study (the pool allowed to work it). See CONTEXT.md (Country
// Assignment) and src/domains/authz/assignments (EM-only: running ≠ setup).
// ─────────────────────────────────────────────────────────────────────────────

/// One Researcher assigned to one Country within one study. M:N: a Country may
/// have several researchers and a researcher works many countries/studies. The
/// @@unique makes assignment idempotent/additive (re-assigning is a no-op; #6
/// never removes — removal is tracked separately as #25). `country` is the
/// canonical name and matches a BenchmarkItem.country in the same study — a
/// country is only assignable once it has Benchmark Items (the brief defines a
/// study's countries; ADR-0009). It is a plain string, not an FK: the Benchmark
/// Item identity is (study, country, partNumberKey), so there is no single row
/// to reference — that integrity is enforced by the repository, consistent with
/// the app-layer-first policy (ADR-0008). `assignedById` records the EM who made
/// the assignment for provenance (audit log is #16/#42).
model CountryAssignment {
  id           String   @id @default(cuid())
  studyId      String
  // Denormalized owning tenant — the RLS backstop column (ADR-0021). Immutable,
  // copied from the parent study on insert; verified by WITH CHECK.
  clientId     String
  country      String
  researcherId String
  assignedById String
  createdAt    DateTime @default(now())

  study      Study @relation(fields: [studyId], references: [id], onDelete: Cascade)
  researcher User  @relation("AssignedResearcher", fields: [researcherId], references: [id], onDelete: Restrict)
  assignedBy User  @relation("AssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@unique([studyId, country, researcherId])
  @@index([researcherId])
  @@index([studyId])
  @@index([clientId])
  @@map("country_assignment")
}

// ─────────────────────────────────────────────────────────────────────────────
// Market Quote + Quote Line (#87) — the two-level aggregate that replaces the
// flat Quote (ADR-0026). A Market Quote is one dealer's quotation DOCUMENT (one
// source, date, currency, and the single pinned conversion); it HAS MANY Quote
// Lines, one per Benchmark Item it prices. The Market Quote has NO lifecycle
// state — state lives on the line. Numbering is two per-(study, country) counters
// held on QuoteNumberSequence. See CONTEXT.md (Market Quote, Quote Line, Market
// Quote Number, Quote Line Number) and ADRs 0026/0010(superseded)/0011/0021.
// ─────────────────────────────────────────────────────────────────────────────

/// The Quote Lifecycle states (CONTEXT.md), carried on the Quote LINE (ADR-0026 —
/// the Market Quote has none). Draft→Submitted is the only researcher transition;
/// analyst verdicts (#11) move it on. The persisted mirror of QuoteState.
enum QuoteState {
  Draft
  Submitted
  Approved
  Rejected
}

/// Where a MARKET QUOTE's currency conversion stands — one status for the whole
/// document, not per line (CONTEXT.md: Conversion Status, ADR-0004/0026). NULLABLE;
/// null = unconverted (lines still Draft). `pending` = submitted, awaiting the
/// worker (no USD figures, blocks approval of every line); `auto` = a provider rate
/// pinned; `manual` = analyst override (sticky). Pure mirror of ConversionStatus.
enum ConversionStatus {
  pending
  auto
  manual
}

/// The researcher's per-line confidence in a Quote Line (CONTEXT.md: Quote Line).
/// Per-line (may vary across a document) and defaulted at entry; nullable — a
/// migrated walking-skeleton line has no recorded assessment (#87).
enum ConfidenceCode {
  High
  Moderate
  Low
}

/// One dealer's quotation document (ADR-0026): the facts shared by all its lines —
/// source name, Dealer Country + locality, url, the Date Quote Received, the local
/// currency (ADR-0032), and the
/// single pinned conversion (`exchangeRate`/`rateDate`/`conversionStatus`, null
/// until the document is submitted; pinned per document in a later slice). It has
/// NO lifecycle state of its own. `marketQuoteNumber` is the per-(study, country)
/// document label (restarts per market); the @@unique is its backstop. `createdById`
/// is the single author who collected the document — only they add/edit/submit its
/// lines. `studyId`/`country` scope the numbering and tenant; `clientId` is the RLS
/// backstop (ADR-0021), copied from the study on insert and verified by WITH CHECK.
model MarketQuote {
  id          String   @id @default(cuid())
  studyId     String
  // Denormalized owning tenant — the RLS backstop column (ADR-0021), copied from
  // the parent study on insert; verified by WITH CHECK.
  clientId    String
  country     String
  marketQuoteNumber Int
  createdById String

  sourceName        String?
  sourceLocality    String?
  sourceCountry     String?
  sourceUrl         String?
  currency          String?
  dateQuoteReceived DateTime?

  // The single pinned conversion for the whole document (#9 / ADR-0004/0026). Null
  // until the document is submitted; one rate drives every line's derived USD.
  exchangeRate     Decimal?          @db.Decimal(18, 8)
  rateDate         DateTime?
  conversionStatus ConversionStatus?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  study      Study       @relation(fields: [studyId], references: [id], onDelete: Cascade)
  createdBy  User        @relation("MarketQuoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  quoteLines QuoteLine[]

  @@unique([studyId, country, marketQuoteNumber])
  @@index([studyId])
  @@index([createdById])
  @@index([clientId])
  @@map("market_quote")
}

/// One competitive data point within a Market Quote (ADR-0026): the competitor's
/// equivalent part priced against one Benchmark Item, CARRYING THE LIFECYCLE
/// `state`. Per-item facts are all nullable (a Draft saves partial data; required-
/// ness is enforced only by the pure lifecycle core at submit). `quoteLineNumber`
/// is the stored, stable flat per-(study, country) handle ("Row 87"); the @@unique
/// on (studyId, country, quoteLineNumber) is its backstop, and @@unique
/// (marketQuoteId, benchmarkItemId) enforces exactly one line per item per document.
/// `studyId`/`country`/`clientId`/`createdById` are denormalized scoping scalars
/// copied from the parent document on insert — `clientId` is the RLS backstop
/// (ADR-0021, WITH CHECK), `createdById` keeps owner-only writes and Draft-privacy
/// reads (ADR-0011) join-free. The derived USD figures live here (each from the
/// document's one rate); the rate/status itself lives on the MarketQuote.
model QuoteLine {
  id            String     @id @default(cuid())
  marketQuoteId String
  benchmarkItemId String
  // Denormalized scoping scalars (ADR-0026), copied from the parent document on
  // insert. `clientId` is the RLS backstop (ADR-0021); `studyId`/`country` scope
  // the Quote Line Number; `createdById` is the document's author.
  clientId      String
  studyId       String
  country       String
  createdById   String
  quoteLineNumber Int
  state         QuoteState @default(Draft)

  // Competitor identity + descriptive part fields. Brand is per-line (defaulted at
  // entry, may vary across a document).
  competitorBrand          String?
  competitorPartNumber     String?
  competitorPartDescription String?

  price          Decimal? @db.Decimal(14, 4)
  quantityQuoted Int?
  stockStatus    String?

  // Structured lead time (value + unit) — replaces the flat free-text `leadTime`.
  leadTimeValue Decimal? @db.Decimal(14, 4)
  leadTimeUnit  String?

  // Warranty Offered? — the Yes/No gate over the two warranty pairs (ADR-0037).
  // Tri-state nullable boolean (null = unanswered) like discountAvailable; the
  // answer is required to submit and, when not Yes, the pairs below are cleared.
  warrantyOffered Boolean?

  // Up to two warranties, each a value + unit pair (shown only when Offered = Yes).
  warranty1Value Decimal? @db.Decimal(14, 4)
  warranty1Unit  String?
  warranty2Value Decimal? @db.Decimal(14, 4)
  warranty2Unit  String?

  // Discount: available + applied flags, value + type.
  discountAvailable Boolean?
  discountApplied   Boolean?
  discountValue     Decimal? @db.Decimal(14, 4)
  discountType      String?

  // Landed cost: a flag the price already includes it, plus a free-text note.
  landedCostIncluded Boolean?
  landedCostNote     String?

  // Two free-text notes. On migration the old `notes` maps to `notes` 1:1 and the
  // legacy leadTime/warranty/discount strings fold into `notesSecondary` (#87).
  notes          String?
  notesSecondary String?

  confidenceCode ConfidenceCode?
  paperQuote     Boolean         @default(false)

  // Derived USD figures (#9 / ADR-0004/0026), each computed from the parent
  // document's one pinned rate; never hand-entered.
  convertedUsdPrice        Decimal? @db.Decimal(14, 4)
  convertedUsdPricePerUnit Decimal? @db.Decimal(14, 4)

  // Analyst review (#11 / ADR-0014), per line. `submittedAt` stamps FIFO position;
  // `rejectionReason` carries the analyst's reason (cleared on resubmit);
  // `reviewedById`/`reviewedAt` record the latest verdict; `justification` persists
  // across resubmit (the analyst must read it to approve a flagged line).
  submittedAt     DateTime?
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?
  justification   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  marketQuote   MarketQuote   @relation(fields: [marketQuoteId], references: [id], onDelete: Cascade)
  benchmarkItem BenchmarkItem @relation(fields: [benchmarkItemId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("QuoteLineCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  reviewedBy    User?         @relation("QuoteLineReviewedBy", fields: [reviewedById], references: [id], onDelete: Restrict)

  @@unique([marketQuoteId, benchmarkItemId])
  @@unique([studyId, country, quoteLineNumber])
  @@index([marketQuoteId])
  @@index([benchmarkItemId])
  @@index([createdById])
  @@index([reviewedById])
  @@index([clientId])
  @@map("quote_line")
}

/// The per-(study, country) home for the two monotonic counters that supersede
/// ADR-0010's per-item `quoteSeq` (ADR-0026). There is no guaranteed row at this
/// grain (a CountryRelease exists only after release), so this lightweight row is
/// created LAZILY on first allocation and incremented atomically with a single
/// `INSERT … ON CONFLICT (studyId, country) DO UPDATE SET seq = seq + 1 RETURNING`
/// — the maybe-absent-row generalization of ADR-0010's atomic-increment idiom.
/// `marketQuoteSeq` restarts per market; `quoteLineSeq` is the flat 1..N handle.
/// Gaps are intended (a hard-deleted document/line is never renumbered). `clientId`
/// is the RLS backstop (ADR-0021).
model QuoteNumberSequence {
  id        String @id @default(cuid())
  studyId   String
  clientId  String
  country   String
  marketQuoteSeq Int @default(0)
  quoteLineSeq   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  study Study @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@unique([studyId, country])
  @@index([clientId])
  @@map("quote_number_sequence")
}

// ─────────────────────────────────────────────────────────────────────────────
// Country Release (#13) — the second of the two release gates (ADR-0002): an
// Analyst makes a Country's approved quotes visible to the client, as a set.
// See CONTEXT.md (Released, Release Eligibility) and ADR-0016. A Country has no
// row of its own (it is a string on BenchmarkItem); this is where its release
// state lives, one row per (study, country).
// ─────────────────────────────────────────────────────────────────────────────

/// Whether a Country's release is currently in effect. `released` = its approved
/// quotes are client-visible; `reopened` = pulled back from client view pending
/// re-release. The pure mirror of ReleaseState the repository persists.
enum ReleaseState {
  released
  reopened
}

/// The release state of one Country within one study (ADR-0016). Keyed on
/// (studyId, country) — the same country recurs across studies and each releases
/// independently. The row is created on first release and MUTATED IN PLACE
/// thereafter, never deleted: reopen flips `state` to `reopened` (keeping the
/// release stamps) and re-release flips it back and re-stamps, so the row keeps
/// its own provenance for the audit slice (#16/#42). "Currently released" ⇔
/// `state = released`; no row ⇔ never released. `country` is a plain string (not
/// an FK), consistent with CountryAssignment — the Benchmark Item identity is
/// (study, country, partNumberKey), so there is no single row to reference; the
/// repository enforces that the country has Benchmark Items. The eligibility
/// precondition is a pure, derived judgement (src/domains/release), never stored.
model CountryRelease {
  id           String       @id @default(cuid())
  studyId      String
  // Denormalized owning tenant — the RLS backstop column (ADR-0021). Immutable,
  // copied from the parent study on insert; verified by WITH CHECK.
  clientId     String
  country      String
  state        ReleaseState
  releasedById String
  releasedAt   DateTime
  reopenedById String?
  reopenedAt   DateTime?
  // First time this (study, country) was ever released — set once, NEVER cleared
  // by a reopen or re-release (releasedAt re-stamps; this does not). Its presence
  // is the in-transaction guard that suppresses re-release client notifications,
  // so the tenant is told a Country is released exactly once (#17 / ADR-0020).
  clientNotifiedAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  study      Study @relation(fields: [studyId], references: [id], onDelete: Cascade)
  releasedBy User  @relation("ReleasedBy", fields: [releasedById], references: [id], onDelete: Restrict)
  reopenedBy User? @relation("ReopenedBy", fields: [reopenedById], references: [id], onDelete: Restrict)

  @@unique([studyId, country])
  @@index([studyId])
  @@index([clientId])
  @@map("country_release")
}

// ─────────────────────────────────────────────────────────────────────────────
// Export Audit (#15) — a record that a sensitive Internal Export of a study's
// full data actually happened. See CONTEXT.md (Internal Export) and ADR-0018:
// this is a STANDALONE audit row, deliberately not waiting for the general audit
// log (#16/#42). Only Internal Exports are audited — a Client Export of a
// tenant's own released data is not a sensitive access.
// ─────────────────────────────────────────────────────────────────────────────

/// One successful Internal Export. `clientId` is the exported tenant, denormalized
/// so "who exported tenant X's data" is a direct query (an Internal Export is run
/// by cross-tenant internal staff, so the tenant isn't implied by the user). The
/// row is written only AFTER the workbook is generated (ADR-0018): an export that
/// errored produced no bytes and logs nothing. `exportType` is "internal" today;
/// the column leaves room should an audited Client Export ever be added.
model ExportAudit {
  id         String   @id @default(cuid())
  userId     String
  clientId   String
  studyId    String
  exportType String
  createdAt  DateTime @default(now())

  user User @relation("ExportRunBy", fields: [userId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([studyId])
  @@index([userId])
  @@map("export_audit")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit Event (#16) — the append-only internal trail of significant state
// transitions. See CONTEXT.md (Audit Event, Audit Action) and ADR-0019: ONE
// generic table written ATOMICALLY inside each transition's transaction, the
// persisted mirror of the typed union in src/domains/audit. Distinct from the
// standalone ExportAudit (ADR-0018), which records data access, not change.
// ─────────────────────────────────────────────────────────────────────────────

/// The closed set of audited transitions (CONTEXT.md: Audit Action). Each fixes
/// the subject type it applies to and whether it carries a before/after value.
enum AuditAction {
  submit
  approve
  reject
  release
  reopen
  import
  clientPriceChange
  manualRateOverride
  assign
  // An EM/Analyst set or edited a Study Exchange Rate row (ADR-0041) — subject
  // StudyExchangeRate, null monetary pair (a Decimal(18,8) rate won't fit the
  // pair's Decimal(14,4), so the value lives on the row).
  studyRateSet
}

/// The kind of entity an Audit Event is about. The subject id is a plain string,
/// not an FK (polymorphic) — append-only history may outlive its subject, and
/// integrity is enforced app-layer-first (ADR-0008), as with the country strings
/// on CountryAssignment/CountryRelease.
enum AuditSubjectType {
  // `Quote` is RETAINED as a legacy value (ADR-0026): pre-split history rows keep
  // it, and because the migration preserves line ids, their subjectId still
  // resolves. New events use MarketQuote (submit) / QuoteLine (approve/reject).
  Quote
  MarketQuote
  QuoteLine
  BenchmarkItem
  CountryRelease
  CountryAssignment
  StudyExchangeRate
}

/// One append-only record that a significant transition happened (ADR-0019).
/// `actorId` is the User who did it (the one real FK; an actor is always a live
/// user). `studyId` is denormalized so a study's timeline is one indexed query
/// (mirroring ExportAudit.clientId). `subjectType`/`subjectId` are polymorphic.
/// `beforeValue`/`afterValue` carry a monetary delta for the transitions that
/// change one — `clientPriceChange` (Decimal(14,4) matches BenchmarkItem.clientPrice)
/// and `manualRateOverride` (after = the newly-pinned convertedUsdPrice; ADR-0023);
/// null for every other action. Rows are written, never updated or deleted — a
/// correction is a new event.
model AuditEvent {
  id          String           @id @default(cuid())
  action      AuditAction
  actorId     String
  studyId     String
  subjectType AuditSubjectType
  subjectId   String
  beforeValue Decimal?         @db.Decimal(14, 4)
  afterValue  Decimal?         @db.Decimal(14, 4)
  createdAt   DateTime         @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([studyId, createdAt])
  @@index([subjectType, subjectId])
  @@index([actorId])
  @@map("audit_event")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications (#17) — the only two v1 events that PUSH rather than wait to be
// pulled: a Quote rejected (to its author) and a Country released (to the
// tenant's Client Users). See CONTEXT.md (Notification) and ADR-0020. One row is
// one in-app notification AND the outbox entry the worker emails from; the in-app
// row is written in the transition's own transaction (like AuditEvent), email is
// a deferred graphile-worker job. Snapshots its display text so it survives the
// source mutating (a rejection reason is cleared on resubmit).
// ─────────────────────────────────────────────────────────────────────────────

/// The two push events. The pure mirror of NotificationKind in src/domains.
enum NotificationKind {
  quoteRejected
  countryReleased
}

/// What a Notification links back to. Polymorphic plain-string subjectId, like
/// AuditEvent — no FK (the source may change or be revised after the snapshot).
enum NotificationSubjectType {
  // `Quote` retained as a legacy value (ADR-0026); pre-split rejection
  // notifications keep it and still resolve (line ids are preserved). New
  // rejection notifications target QuoteLine.
  Quote
  QuoteLine
  CountryRelease
}

/// One push signal to one recipient (ADR-0020). `recipientId` is the only FK (a
/// recipient is always a live User; deactivated users are never written). `kind`
/// + `subjectType`/`subjectId` link back; `studyId` is denormalized for scoping.
/// `reason` snapshots a rejection's reason (ephemeral — cleared on resubmit);
/// `country` snapshots a release's country; each is null for the other kind.
/// `readAt` is in-app read state (marked on inbox open); `emailedAt` is delivery
/// provenance the worker stamps after Resend succeeds (NOT a polling cursor —
/// at-least-once delivery is owned by the graphile job, ADR-0020).
model Notification {
  id          String                  @id @default(cuid())
  recipientId String
  kind        NotificationKind
  studyId     String
  subjectType NotificationSubjectType
  subjectId   String
  reason      String?
  country     String?
  readAt      DateTime?
  emailedAt   DateTime?
  createdAt   DateTime                @default(now())

  recipient User @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Restrict)

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
  @@map("notification")
}
